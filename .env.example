# MongoDB Atlas connection string
# Get it from: Atlas → Cluster → Connect → Drivers → copy the URI.
# Replace <db_user>, <password>, and append a database name (e.g. /dailytracker).
# Example: mongodb+srv://app_user:STRONG_PASSWORD@cluster0.xxxxx.mongodb.net/dailytracker?retryWrites=true&w=majority
MONGODB_URI="mongodb+srv://<user>:<password>@<host>/dailytracker?retryWrites=true&w=majority"

# Long random string used to sign JWT session cookies.
# Generate one with: openssl rand -base64 48
AUTH_SECRET="change-me-to-a-long-random-string"

# Optional — name of the session cookie (defaults to "dt_session" if unset)
# AUTH_COOKIE_NAME="dt_session"
